data-v-5f641036=3D"" class=3D"user-content">&lt;script&gt;
// Sample Products Data - Easy to edit
const products =3D [
  {
    id: 1,
    name: "Emerald Silk Gown",
    price: 18500,
    image: "images/emerald-gown.jpg",
    description: "Timeless elegance with a modern twist",
    category: "Evening Wear"
  },
  {
    id: 2,
    name: "Cashmere Wool Coat",
    price: 24500,
    image: "images/cashmere-coat.jpg",
    description: "Luxurious Italian wool blend",
    category: "Outerwear"
  },
  {
    id: 3,
    name: "Leather Crossbody Bag",
    price: 9200,
    image: "images/leather-bag.jpg",
    description: "Handcrafted genuine leather",
    category: "Accessories"
  },
  {
    id: 4,
    name: "Pearl Embellished Blouse",
    price: 7800,
    image: "images/pearl-blouse.jpg",
    description: "Delicate hand-embellished details",
    category: "Tops"
  }
];

// Function to render products
function renderProducts() {
  const grid =3D document.getElementById('products-grid');
  grid.innerHTML =3D '';

  products.forEach(product =3D&gt; {
    const card =3D document.createElement('div');
    card.className =3D 'product-card';
    card.innerHTML =3D `
      &lt;div class=3D"product-image"&gt;
        &lt;img src=3D"${product.image}" alt=3D"${product.name}"&gt;
      &lt;/div&gt;
      &lt;div class=3D"product-info"&gt;
        &lt;h3&gt;${product.name}&lt;/h3&gt;
        &lt;p class=3D"description"&gt;${product.description}&lt;/p&gt;
        &lt;div class=3D"price"&gt;KSh ${product.price.toLocaleString()}&lt=
;/div&gt;
        &lt;button class=3D"add-to-closet" data-id=3D"${product.id}"&gt;
          Add to Closet
        &lt;/button&gt;
      &lt;/div&gt;
    `;
    grid.appendChild(card);
  });

  // Add event listeners to buttons
  document.querySelectorAll('.add-to-closet').forEach(button =3D&gt; {
    button.addEventListener('click', (e) =3D&gt; {
      const productId =3D parseInt(e.target.dataset.id);
      const product =3D products.find(p =3D&gt; p.id =3D=3D=3D productId);
      addToCloset(product);
    });
  });
}

// Add to Closet Function (connects to your existing cart)
function addToCloset(product) {
  let closet =3D JSON.parse(localStorage.getItem('closet')) || [];
 =20
  // Check if already in closet
  if (closet.find(item =3D&gt; item.id =3D=3D=3D product.id)) {
    alert(`${product.name} is already in your closet!`);
    return;
  }

  closet.push(product);
  localStorage.setItem('closet', JSON.stringify(closet));
 =20
  // Optional: Show success message
  const message =3D document.createElement('div');
  message.textContent =3D `${product.name} added to closet`;
  message.style.cssText =3D 'position:fixed; bottom:20px; right:20px; backg=
round:#000; color:#fff; padding:15px 20px; border-radius:8px;';
  document.body.appendChild(message);
 =20
  setTimeout(() =3D&gt; message.remove(), 2500);
 =20
  // If you have a function to update cart count/sidebar, call it here
  if (typeof updateClosetUI =3D=3D=3D 'function') updateClosetUI();
}

// Initialize products when page loads
document.addEventListener('DOMContentLoaded', renderProducts);
